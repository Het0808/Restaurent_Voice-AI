# Application identity
APP_NAME="Multilingual AI Restaurant Voice Receptionist"
APP_ENV=development
APP_VERSION=0.8.0
DEBUG=false
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL reservation database (local development example only)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/restaurant_voice_ai
DB_ECHO=false
DEFAULT_RESERVATION_DURATION_MINUTES=90
RESTAURANT_TIMEZONE=Asia/Kolkata
MAX_PARTY_SIZE=20

# Embeddings: google (default), openai, or local. Keep API keys blank in Git.
EMBEDDING_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Restaurant knowledge retrieval
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=restaurant_knowledge
RAG_TOP_K=5
RAG_VECTOR_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
RAG_SCORE_THRESHOLD=0.15
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# Stage 6 conversation: rules, google, or hybrid (Google with deterministic fallback)
CONVERSATION_MODE=hybrid
CONVERSATION_INTENT_PROVIDER=google
CONVERSATION_ENTITY_PROVIDER=google
CONVERSATION_RESPONSE_PROVIDER=google
GOOGLE_CHAT_MODEL=
CONVERSATION_MEMORY_BACKEND=memory
CONVERSATION_MAX_HISTORY_MESSAGES=20
CONVERSATION_MAX_TOOL_ITERATIONS=3
CONVERSATION_REQUIRE_MUTATION_CONFIRMATION=true
CONVERSATION_MEMORY_TTL_SECONDS=3600

# Stage 7 browser voice transport (offline fake providers by default)
VOICE_ENABLED=true
VOICE_STT_PROVIDER=fake
VOICE_TTS_PROVIDER=fake
VOICE_VAD_PROVIDER=energy
VOICE_INPUT_FORMAT=pcm_s16le
VOICE_INPUT_SAMPLE_RATE=16000
VOICE_INPUT_CHANNELS=1
VOICE_OUTPUT_FORMAT=pcm_s16le
VOICE_OUTPUT_SAMPLE_RATE=24000
VOICE_OUTPUT_CHANNELS=1
VOICE_FRAME_DURATION_MS=20
VOICE_MAX_FRAME_BYTES=65536
VOICE_MAX_UTTERANCE_SECONDS=30
VOICE_MAX_SESSION_SECONDS=1800
VOICE_SESSION_IDLE_TIMEOUT_SECONDS=120
VOICE_END_SILENCE_MS=700
VOICE_MIN_SPEECH_MS=200
VOICE_PRE_SPEECH_BUFFER_MS=300
VOICE_ENERGY_THRESHOLD=500
VOICE_TTS_CHUNK_BYTES=4096
VOICE_MAX_TRANSCRIPT_CHARS=2000
VOICE_ALLOW_PARTIAL_TRANSCRIPTS=true
VOICE_ALLOW_BARGE_IN=true
VOICE_SUPPORTED_LANGUAGES=["en-IN","hi-IN","gu-IN"]
VOICE_DEFAULT_LANGUAGE=en-IN
VOICE_ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
VOICE_MAX_JSON_BYTES=16384
VOICE_MAX_SESSIONS=100
VOICE_MAX_PENDING_FRAMES=100
VOICE_STT_TIMEOUT_SECONDS=15
VOICE_CONVERSATION_TIMEOUT_SECONDS=30
VOICE_TTS_TIMEOUT_SECONDS=15
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_STT_LOCATION=global
GOOGLE_CLOUD_STT_RECOGNIZER=
GOOGLE_CLOUD_STT_MODEL=latest_short
GOOGLE_CLOUD_TTS_VOICE=

# Stage 8A production-readiness infrastructure
LOG_FORMAT=text
API_AUTH_ENABLED=false
API_KEY_HEADER_NAME=X-API-Key
API_KEYS=[]
ADMIN_API_KEYS=[]
PUBLIC_HEALTH_ENDPOINTS=true
WEBSOCKET_QUERY_API_KEY_ENABLED=false
REQUEST_ID_HEADER=X-Request-ID
TRUSTED_HOSTS=["localhost","127.0.0.1"]
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
TRUST_PROXY_HEADERS=false
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=restaurant_voice_ai
REDIS_CONNECT_TIMEOUT_SECONDS=3
REDIS_SOCKET_TIMEOUT_SECONDS=3
REDIS_MAX_CONNECTIONS=20
IDEMPOTENCY_BACKEND=memory
RATE_LIMIT_BACKEND=memory
CONVERSATION_HISTORY_ENABLED=true
CONVERSATION_HISTORY_RETENTION_DAYS=30
CONVERSATION_HISTORY_STORE_RAW_AUDIO=false
CONVERSATION_HISTORY_STORE_TRANSCRIPTS=true
CONVERSATION_HISTORY_STORE_PHONE_MASKED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TEXT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_VOICE_CONNECTIONS_PER_MINUTE=10
RATE_LIMIT_HEALTH_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST_MULTIPLIER=2
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_INCLUDE_ROUTE_LABELS=true
METRICS_PUBLIC=false
LIVENESS_PATH=/health/live
READINESS_PATH=/health/ready
HEALTH_PATH=/health
SHUTDOWN_GRACE_SECONDS=15
STARTUP_DATABASE_TIMEOUT_SECONDS=30
STARTUP_REDIS_TIMEOUT_SECONDS=10
PRODUCTION_ALLOW_FAKE_VOICE=false

# Stage 8C Twilio incoming calls and Gemini conversation model
PUBLIC_BASE_URL=https://your-tunnel.example
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_STAFF_PHONE_NUMBER=
TWILIO_VALIDATE_SIGNATURES=true
TWILIO_VOICE_NAME=Polly.Aditi
TWILIO_VOICE_LANGUAGE=en-IN
TWILIO_SPEECH_TIMEOUT=auto
TWILIO_MAX_SPEECH_SECONDS=20
TWILIO_MAX_RETRIES=3
TWILIO_MIN_SPEECH_CONFIDENCE=0.45
TWILIO_WEBHOOK_MAX_CHARS=4000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
