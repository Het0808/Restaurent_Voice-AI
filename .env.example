# Application identity
APP_NAME="Multilingual AI Restaurant Voice Receptionist"
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# Development server
HOST=127.0.0.1
PORT=8000

# Logging and routing
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# JSON array of explicitly allowed browser origins. Do not use "*" with credentials.
CORS_ORIGINS=["http://localhost:3000"]
